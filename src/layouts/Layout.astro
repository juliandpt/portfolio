---
// Supports weights 100-900
import "@fontsource-variable/inter";

import Header from "../sections/Header.astro";
import Footer from "../sections/Footer.astro";

const { description } = Astro.props;
---

<html lang="en" class="dark">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <title>Julián de Pablo</title>
    </head>

    <body class="text-black dark:text-white bg-white dark:bg-black">
        <Header />

        <slot />

        <Footer />
    </body>
</html>

<style is:global>
    @font-face {
        font-family: "Favorit";
        src: url("/fonts/Favorit.otf") format("OpenType");
    }

    html {
        font-family: "Favorit", sans-serif;
    }

    .font-inter {
        font-family: "Inter Variable", sans-serif;
    }

    .fadeInImage {
        animation: fadeInAnimation ease 6s;
        animation-iteration-count: 1;
        animation-fill-mode: forwards;
    }

    .fadeInText {
        animation: fadeInAnimation ease 3s;
        animation-delay: 1s;
        animation-iteration-count: 1;
        animation-fill-mode: forwards;
    }

    nav {
        animation: nav-shadown 1s linear both;
        animation-timeline: scroll();
        animation-range: 0 1px;
    }

    @keyframes nav-shadown {
        to {
            @apply shadow-lg backdrop-blur border border-neutral-800 dark:border-neutral-200;
        }
    }

    ol.relative li:last-child .guide span {
        width: 0;
    }

    @keyframes fadeInAnimation {
        0% {
            opacity: 0;
        }
        100% {
            opacity: 1;
        }
    }

    section {
        animation: reveal linear both 1s;
        animation-timeline: view();
        animation-range: entry 45% cover 30%;
    }

    @keyframes reveal {
        from {
            opacity: 0;
            translate: 0 50px;
        }
        to {
            opacity: 1;
        }
    }

    @keyframes roation {
        0% {
            --gradient-angle: 0deg;
        }
        100% {
            --gradient-angle: 360deg;
        }
    }

    .rotation-background {
        content: "";
        inset: 0;
        background: conic-gradient(
            from var(--gradient-angle),
            var(white),
            var(black),
            var(white)
        );
        border-radius: inherit;
        animation: roation 5s linear infinite;
    }
</style>
