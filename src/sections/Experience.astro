---
const JOBS = [
    {
        company: "SAS",
        logo: "/images/sas.webp",
        startDate: "Octubre 2021",
        endDate: "Abril 2025",
        positions: [
            {
                title: "Associate Technical Consultant",
                startDate: "Abril 2023",
                endDate: "Abril 2025",
            },
            {
                title: "Contractor",
                startDate: "Septiembre 2022",
                endDate: "Abril 2023",
            },
            {
                title: "Technical Intern",
                startDate: "Octubre 2021",
                endDate: "Septiembre 2022",
            },
        ],
    },
    {
        company: "CaixaBank Tech",
        logo: "/images/caixabank.webp",
        startDate: "Abril 2025",
        endDate: "Actualidad",
        positions: [
            {
                title: "Software Engineer",
                startDate: "Abril 2025",
                endDate: "Actualidad",
            },
        ],
    },
];
---

<div id="experiences" class="relative flex flex-col mt-8 w-full max-w-[700px] mx-auto bg-transparent backdrop-blur">
    {
        JOBS.reverse().map((job) => (
            <div class="relative w-full">
                <div class="flex">
                    <img
                        src={job.logo}
                        alt={job.company}
                        class="w-12 h-12 rounded"
                    />

                    <div class="pl-4">
                        <h4 class="font-extrabold text-2xl text-left">
                            {" "}
                            {job.company}{" "}
                        </h4>

                        <time class="text-sm text-left">
                            {" "}
                            {job.startDate} - {job.endDate}{" "}
                        </time>
                    </div>
                </div>

                <ol class="relative">
                    {job.positions?.map((position) => (
                        <li class="first:mt-6 group">
                            <div class="relative flex items-center">
                                <span class="rounded w-2 h-2 mx-5 bg-white/20" />

                                <h3 class="pl-4 text-lg font-semibold text-white">
                                    {" "}
                                    {position.title}{" "}
                                </h3>
                            </div>

                            <div class="flex guide">
                                <span class="rouned-full w-[2px] h-auto mx-[23px] bg-white/20" />

                                <div class="pl-4 mb-8 group-last-of-type:mb-0">
                                    <time class="mb-1 text-xs font-normal leading-none text-white/50">
                                        {" "}
                                        {position.startDate} - {" "}
                                        {position.endDate}{" "}
                                    </time>
                                </div>
                            </div>
                        </li>
                    ))}
                </ol>
            </div>

            <hr class="h-[1px] my-14 border-0 bg-gradient-to-r from-white/40 from-90% to-transparent last:w-0 last:m-0"></hr>
        ))
    }
</div>
