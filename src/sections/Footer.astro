        <a href={ link.url } class="mx-4 text-xs hover:text-black hover:[text-shadow:_0_0_20px_black] dark:hover:text-white dark:hover:[text-shadow:_0_0_10px_white] transition duration-1000"> { link.title }</a>
      </li>
      
      <span class="rounded-full w-[2px] h-4 bg-neutral-600 last:w-0"/>
