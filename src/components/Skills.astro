---
import Layout from "../layouts/Layout.astro";
import Title from "./Title.astro";
import { skills, services, projects } from "../services/data"
---


  <div class="container grid mx-auto justify-items-center">

    <Title title="Skills" />

    <div id='skills' class='relative grid grid-cols-1 md:grid-cols-2 gap-10 w-full'>
      {skills.map(skill => (
        <div class='relative items-center p-6 text-black dark:text-white overflow-hidden select-none w-full'>
          <button class='flex items-center justify-between w-full transition-colors cursor-pointer'>
            <h4 class='font-extrabold text-left sm:text-lg'> { skill.title } </h4>
            
            <svg class='flex-shrink-0 w-4 h-4 transition-all duration-200 ease-out transform rotate-0' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
              <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M19 9l-7 7-7-7' />
            </svg>
          </button>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6 hidden">
            {skill.items.map(item => (
              <div class='flex flex-row items-center p-4 overflow-hidden text-black dark:text-white bg-gray-50 dark:bg-[#1F1F1F] select-none w-full'>
                <img src={ item.icon } alt={ item.title } class="w-6 h-auto mr-4" />

                <h5> { item.title } </h5>
              </div>
            ))}
          </div>
        </div>
      ))}
		</div>
  
    <Title title="Services" />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-3.5 md:gap-7">
      <div class="p-6 bg-transparent border-2 border-black dark:border-white">
        <svg class="w-10 h-10 mb-4 dark:fill-white" xmlns="http://www.w3.org/2000/svg">
          <path d="M2.5,8.86l9,5.2a1,1,0,0,0,1,0l9-5.2A1,1,0,0,0,22,8a1,1,0,0,0-.5-.87l-9-5.19a1,1,0,0,0-1,0l-9,5.19A1,1,0,0,0,2,8,1,1,0,0,0,2.5,8.86ZM12,4l7,4-7,4L5,8Zm8.5,7.17L12,16,3.5,11.13a1,1,0,0,0-1.37.37,1,1,0,0,0,.37,1.36l9,5.2a1,1,0,0,0,1,0l9-5.2a1,1,0,0,0,.37-1.36A1,1,0,0,0,20.5,11.13Zm0,4L12,20,3.5,15.13a1,1,0,0,0-1.37.37,1,1,0,0,0,.37,1.36l9,5.2a1,1,0,0,0,1,0l9-5.2a1,1,0,0,0,.37-1.36A1,1,0,0,0,20.5,15.13Z" />
        </svg>
        
        <h5 class="mb-4 text-2xl font-semibold text-gray-900 dark:text-white">Web development</h5>

        <p class="mb-3 font-normal text-gray-500 dark:text-gray-400">I perform modern web pages, having knowledge of Multiple frameworks in a Fullstack development.</p>
      </div>

      <div class="p-6 bg-transparent border-2 border-black dark:border-white">
        <svg class="w-10 h-10 mb-4 fill-black dark:fill-white" xmlns="http://www.w3.org/2000/svg">
          <path d="M10,13H3a1,1,0,0,0-1,1v7a1,1,0,0,0,1,1h7a1,1,0,0,0,1-1V14A1,1,0,0,0,10,13ZM9,20H4V15H9ZM21,2H14a1,1,0,0,0-1,1v7a1,1,0,0,0,1,1h7a1,1,0,0,0,1-1V3A1,1,0,0,0,21,2ZM20,9H15V4h5Zm1,4H14a1,1,0,0,0-1,1v7a1,1,0,0,0,1,1h7a1,1,0,0,0,1-1V14A1,1,0,0,0,21,13Zm-1,7H15V15h5ZM10,2H3A1,1,0,0,0,2,3v7a1,1,0,0,0,1,1h7a1,1,0,0,0,1-1V3A1,1,0,0,0,10,2ZM9,9H4V4H9Z"/>
        </svg>
        
        <h5 class="mb-4 text-2xl font-semibold tracking-tight text-gray-900 dark:text-white">UI / UX Design</h5>

        <p class="mb-3 font-normal text-gray-500 dark:text-gray-400">I develope the user interface, design web pages and create ux element interactions.</p>
      </div>

      <div class="p-6 bg-transparent border-2 border-black dark:border-white">
        <svg class="w-10 h-10 mb-4 fill-black dark:fill-white" xmlns="http://www.w3.org/2000/svg">
          <path d="M5.0333 14.8284L6.44751 16.2426L10.6902 12L6.44751 7.75733L5.0333 9.17155L7.86172 12L5.0333 14.8284Z" />
          <path d="M15 14H11V16H15V14Z" />
          <path fill-rule="evenodd" clip-rule="evenodd" d="M2 2C0.895431 2 0 2.89543 0 4V20C0 21.1046 0.89543 22 2 22H22C23.1046 22 24 21.1046 24 20V4C24 2.89543 23.1046 2 22 2H2ZM22 4H2L2 20H22V4Z" />
        </svg>
        
        <h5 class="mb-4 text-2xl font-semibold tracking-tight text-gray-900 dark:text-white">Software development</h5>

        <p class="mb-6 font-normal text-gray-500 dark:text-gray-400">I develope quality software products, manage software maintenance, and have Knowledge of some of the most popular programming languages.</p>
      </div>

      <div class="p-6 bg-transparenttext border-2 border-black dark:border-white">
        <svg class="w-10 h-10 mb-4 fill-black dark:fill-white" xmlns="http://www.w3.org/2000/svg">
          <path d="M13,11H7a1,1,0,0,0,0,2h6a1,1,0,0,0,0-2Zm4-4H7A1,1,0,0,0,7,9H17a1,1,0,0,0,0-2Zm2-5H5A3,3,0,0,0,2,5V15a3,3,0,0,0,3,3H16.59l3.7,3.71A1,1,0,0,0,21,22a.84.84,0,0,0,.38-.08A1,1,0,0,0,22,21V5A3,3,0,0,0,19,2Zm1,16.59-2.29-2.3A1,1,0,0,0,17,16H5a1,1,0,0,1-1-1V5A1,1,0,0,1,5,4H19a1,1,0,0,1,1,1Z"/>
        </svg>
        
        <h5 class="mb-4 text-2xl font-semibold tracking-tight text-gray-900 dark:text-white">Social skills</h5>

        <p class="mb-6 font-normal text-gray-500 dark:text-gray-400">I am an interactive and communicative person, prefering to work in a team instead of alone.</p>
      </div>
    </div>
  
    <Title title="Projects" subtitle="Work I developed" />

    {projects.map(project => (
      <div class="grid md:grid-cols-2 mb-[10%]">
        <div class="order-last md:order-first">
          <h2 class="text-3xl dark:text-white mb-4"> { project.title } </h2>

          <p class="dark:text-white mb-2"> { project.description } </p>

          <div class="flex align-center mb-9">
            {project.chips.map(chip => (
              <span class="text-xs font-medium dark:text-white inline-flex items-center px-4 py-0.5 my-1 mr-2 border border-black dark:border-white">
                <img alt={ chip.name } src={ chip.icon } class="w-3 h-auto mr-2" />

                { chip.name }
              </span>
            ))}
          </div>

          <div>
            {project.projectLink == null 
              ? ""
              : <a class="font-bold text-center inline-flex items-center px-5 py-2.5 mr-8 border-2 border-black dark:border-white overflow-hidden text-sm text-black group dark:text-white transition-all duration-300 hover:[box-shadow:-7px_7px_0_0_black] hover:-translate-y-2 hover:translate-x-2 dark:hover:[box-shadow:-7px_7px_0_0_white]" href={ project.projectLink } target="_blank" rel="noopener norreferer">
                    Demo

                    <lord-icon
                      src="https://cdn.lordicon.com/zmkotitn.json"
                      trigger="hover"
                      colors="primary:#121331"
                      state="hover-1"
                      class="w-6 h-6 ml-2 dark:fill-white">
                  </lord-icon>
                </a>
            }

            {project.codeLink == null 
              ? ""
              : <a class="font-bold text-center inline-flex items-center px-5 py-2.5 mr-8 border-2 border-black dark:border-white overflow-hidden text-sm text-black group dark:text-white transition-all duration-300 hover:[box-shadow:-7px_7px_0_0_black] hover:-translate-y-2 hover:translate-x-2 dark:hover:[box-shadow:-7px_7px_0_0_white]" href={ project.codeLink } target="_blank" rel="noopener norreferer">
                    Code

                    <svg class="w-6 h-6 ml-2 dark:fill-white" xmlns="http://www.w3.org/2000/svg">
                      <path d="M17.92 11.62a1 1 0 00-.21-.33l-5-5a1 1 0 00-1.42 1.42l3.3 3.29H7a1 1 0 000 2h7.59l-3.3 3.29a1 1 0 000 1.42 1 1 0 001.42 0l5-5a1 1 0 00.21-.33 1 1 0 000-.76z" />
                    </svg>
                </a>
            }
          </div>
        </div>
        
        <video class="w-[90%] h-auto justify-center mx-auto border-2 border-black dark:border-white" muted controls>
          <source src={ project.demo } type="video/mp4">
          Your browser does not support the video tag.
        </video>
      </div>
    ))}
  <div>


<script type='module'>
document.getElementById('skills')?.querySelectorAll('button').forEach((button) => {
	button.addEventListener('click', (event) => {
		const { currentTarget } = event

		const svg = currentTarget.querySelector('svg')
		const isClosed = svg.classList.contains('rotate-0')

		currentTarget.nextElementSibling.classList.toggle('hidden', !isClosed)

		const [from, to] = isClosed ? ['rotate-0', 'rotate-180'] : ['rotate-180', 'rotate-0']
		svg.classList.replace(from, to)
	})
})
</script>